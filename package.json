{
  "name": "resilinetai",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prestart:backend": "node -e \"const fs = require('fs'); fs.mkdirSync('backend/dist/config', { recursive: true }); if (process.env.FIREBASE_CREDENTIALS) { fs.writeFileSync('backend/dist/config/firebase-service-account.json', process.env.FIREBASE_CREDENTIALS); console.log('Wrote credentials from environment variable.'); } else if (fs.existsSync('backend/firebase-services-account.json')) { fs.copyFileSync('backend/firebase-services-account.json', 'backend/dist/config/firebase-service-account.json'); console.log('Copied physical file to destination.'); } else { console.log('Warning: No Firebase credentials identified.'); }\"",
    "start:backend": "npm run prestart:backend && node -r module-alias/register backend/dist/server.js",
    "dev:backend": "ts-node-dev --respawn --transpile-only --project backend/tsconfig.json -r tsconfig-paths/register backend/src/server.ts"
  },
  "dependencies": {
    "@babel/core": "^7.26.0",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@google/generative-ai": "^0.24.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.16.1",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.1",
    "axios": "^1.16.1",
    "babel-preset-expo": "~54.0.10",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.13",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-modules-core": "~3.0.30",
    "expo-notifications": "~0.32.17",
    "expo-status-bar": "~3.0.9",
    "express": "^4.18.2",
    "firebase": "^12.13.0",
    "firebase-admin": "^12.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-maps-directions": "^1.9.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.5.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
